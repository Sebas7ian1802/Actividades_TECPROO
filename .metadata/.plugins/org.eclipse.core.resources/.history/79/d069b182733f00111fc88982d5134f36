package com.upn.ejercicios;

public class Producto {
    // 1. Atributos privados
    private int id;
    private String nombre;
    private double precio;
    private int stock;

    // 2. Constructor
    public Producto(int id, String nombre, double precio, int stock) {
        this.id = id;
        this.nombre = nombre;
        this.precio = precio;
        this.stock = stock;
    }

    // 3. Getters y Setters
    public int getId() {
        return id;
    }

    public void setId(int id) {
        this.id = id;
    }

    public String getNombre() {
        return nombre;
    }

    public void setNombre(String nombre) {
        this.nombre = nombre;
    }

    public double getPrecio() {
        return precio;
    }

    public void setPrecio(double precio) {
        this.precio = precio;
    }

    public int getStock() {
        return stock;
    }

    public void setStock(int stock) {
        this.stock = stock;
    }

    // Método extra recomendado (buena práctica OOP) para imprimir el objeto fácilmente
    @Override
    public String toString() {
        return "ID: " + id + " | Nombre: " + nombre + " | Precio: S/ " + precio + " | Stock: " + stock;
    }
}